    "dataViewMappings": [
        {
            "categorical": {
                "categories": {
                    "for": {
                        "in": "category"
                    },
                    "dataReductionAlgorithm": {
                        "top": {
                            "count": 30000
                        }
                    }
                },
                "values": {
                    "select": [
                        {
                            "bind": {
                                "to": "currentValue"
                            }
                        },
                        {
                            "bind": {
                                "to": "maxValue"
                            }
                        },
                        {
